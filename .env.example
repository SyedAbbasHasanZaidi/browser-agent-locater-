# Copy to .env and fill in real values — never commit .env

# Required for the Vision strategy (Python service calls Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Optional fallback vision provider
OPENAI_API_KEY=sk-...

# URL of the running Python FastAPI vision service
# Local (default):
VISION_SERVICE_URL=http://localhost:8765
# Railway-hosted (uncomment to use):
# VISION_SERVICE_URL=https://your-service.up.railway.app
